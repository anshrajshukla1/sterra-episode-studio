# ── Stera Episode Studio — Environment Variables ────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Neon PostgreSQL async connection URL
# Format: postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Local filesystem paths for uploaded recordings and exported episodes
# In Docker, these should be mounted volumes
RECORDINGS_DIR=/data/recordings
EPISODES_DIR=/data/episodes

# Firebase project ID (from Firebase console → Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Secret key for any internal signing needs (not used for Firebase JWT)
SECRET_KEY=change-me-in-production

# CORS allowed origins — JSON array of strings
CORS_ORIGINS=["http://localhost:5173","https://stera-episode-studio.vercel.app"]
